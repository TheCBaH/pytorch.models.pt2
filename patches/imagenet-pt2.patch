+import os
+import pytest
+
+IMAGENET_DIR = os.path.dirname(os.path.abspath(__file__))
+IMAGE_DIR = os.path.join(IMAGENET_DIR, "data")
+
+
+def pytest_addoption(parser):
+    parser.addoption("--arch", default="resnet18", help="Model architecture (e.g. resnet18).")
+    parser.addoption("--image", action="append", default=None, help="Input image path (repeatable).")
+    parser.addoption(
+        "--labels",
+        default=os.path.join(IMAGENET_DIR, "imagenet_lsvrc_2015_synsets.txt"),
+    )
+    parser.addoption(
+        "--metadata",
+        default=os.path.join(IMAGENET_DIR, "imagenet_metadata.txt"),
+    )
+
+
+@pytest.fixture(scope="session")
+def arch(request):
+    return request.config.getoption("--arch")
+
+
+@pytest.fixture(scope="session")
+def test_images(request):
+    images = request.config.getoption("--image")
+    if not images:
+        if not os.path.isdir(IMAGE_DIR):
+            pytest.skip("No images provided and data/ not found.")
+        images = sorted(
+            os.path.join(IMAGE_DIR, f)
+            for f in os.listdir(IMAGE_DIR)
+            if f.endswith(".jpg")
+        )[:3]
+        if not images:
+            pytest.skip("No .jpg files found in data/")
+    return images
+
+
+@pytest.fixture(scope="session")
+def labels_path(request):
+    return request.config.getoption("--labels")
+
+
+@pytest.fixture(scope="session")
+def metadata_path(request):
+    return request.config.getoption("--metadata")
+
+
+@pytest.fixture(scope="session")
+def model_path(arch):
+    path = os.path.join(IMAGENET_DIR, f"{arch}.pt2")
+    if not os.path.exists(path):
+        pytest.skip(f"Model not found: {path}")
+    return path
+
+
+@pytest.fixture(scope="session")
+def release_zip_path(tmp_path_factory, model_path, arch, test_images, labels_path, metadata_path):
+    import sys
+    sys.path.insert(0, IMAGENET_DIR)
+    import main as imagenet_main
+
+    out = tmp_path_factory.mktemp("release")
+    zip_path = str(out / f"{arch}.release.zip")
+
+    argv = ["--model", model_path, "--output", zip_path]
+    for img in test_images:
+        argv += ["--image", img]
+    if os.path.exists(labels_path):
+        argv += ["--labels", labels_path]
+    if os.path.exists(metadata_path):
+        argv += ["--metadata", metadata_path]
+
+    rc = imagenet_main._pack(argv)
+    assert rc == 0, "_pack() returned non-zero exit code"
+    assert os.path.exists(zip_path), "Release zip was not created"
+    return zip_path
