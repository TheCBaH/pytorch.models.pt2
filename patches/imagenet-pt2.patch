+import io
+import os
+import tempfile
+import zipfile
+
+import torch
+
+IMAGENET_NUM_CLASSES = 1000
+
+
+def test_zip_structure(release_zip_path, arch, test_images, labels_path, metadata_path):
+    with zipfile.ZipFile(release_zip_path) as zf:
+        names = set(zf.namelist())
+
+    assert f"{arch}.pt2" in names
+    if os.path.exists(labels_path):
+        assert "imagenet_lsvrc_2015_synsets.txt" in names
+    if os.path.exists(metadata_path):
+        assert "imagenet_metadata.txt" in names
+
+    pt_files = [n for n in names if n.startswith("images/") and n.endswith(".pt")]
+    assert len(pt_files) == len(test_images), (
+        f"Expected {len(test_images)} image tensors, found {len(pt_files)}"
+    )
+
+
+def test_inference_from_zip(release_zip_path, arch):
+    with zipfile.ZipFile(release_zip_path) as zf:
+        pt_names = sorted(n for n in zf.namelist() if n.startswith("images/") and n.endswith(".pt"))
+        assert pt_names, "No image tensors found in zip"
+
+        with tempfile.TemporaryDirectory() as tmp:
+            model_file = os.path.join(tmp, f"{arch}.pt2")
+            with open(model_file, "wb") as f:
+                f.write(zf.read(f"{arch}.pt2"))
+
+            exported = torch.export.load(model_file)
+
+            for pt_name in pt_names:
+                (tensor,), _ = torch.load(io.BytesIO(zf.read(pt_name)), weights_only=True)
+
+                with torch.no_grad():
+                    output = exported.module()(tensor)
+
+                assert output.shape[-1] == IMAGENET_NUM_CLASSES, (
+                    f"{pt_name}: expected output width {IMAGENET_NUM_CLASSES}, got {output.shape[-1]}"
+                )
+                probs = torch.softmax(output.squeeze(0), dim=0)
+                top1 = int(torch.argmax(probs))
+                assert 0 <= top1 < IMAGENET_NUM_CLASSES
