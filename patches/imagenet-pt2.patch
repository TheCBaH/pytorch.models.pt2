+def _normalize_graph_ids(exported_program) -> None:
+  """Zero out non-deterministic graph_ids in node provenance metadata.
+
+  graph_id is id(Graph) — a CPython memory address that varies across runs,
+  causing spurious diffs in the serialized model.json.
+  """
+  def _zero(ns_list):
+    for ns in (ns_list or []):
+      if ns.node_info is not None:
+        ns.node_info.graph_id = 0
+      _zero(ns.from_node)
+  for node in exported_program.graph.nodes:
+    _zero(node.meta.get('from_node', []))
+
